          ],
          "body": "{\n  \"from_currency\": \"USD\",\n  \"to_currency\": \"GTQ\",\n  \"amount_from\": 100,\n  \"amount_to\": 775,\n  \"rate\": 7.75,\n  \"timestamp\": 1740960000,\n  \"source\": \"cache\"\n}"
        }
      ]
